# Copy this file to `.env` and fill in the values.

# --- Database ---
# Local dev uses SQLite (a file in the project). For production, use Postgres:
#   DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/pawpath?sslmode=require"
# and change the datasource provider in prisma/schema.prisma to "postgresql".
DATABASE_URL="file:./dev.db"

# --- Auth.js (NextAuth v5) ---
# Generate a secret with:  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="replace-with-a-long-random-string"
